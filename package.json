    "@typescript-eslint/eslint-plugin": "^8.9.0",
    "@typescript-eslint/parser": "^8.9.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
