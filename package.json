{
  "name": "feedbackbogen-generator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --open",
    "prebuild": "npm run check:content",
    "build": "vite build",
    "check:content": "node scripts/validate-content.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "preview": "vite preview --port 4173",
    "lint": "eslint src tests vite.config.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest",
    "verify": "npm run check:content && npm run lint && npm run typecheck && npm test -- --run && npm run build"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "docx": "^8.5.0",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "write-excel-file": "^4.0.7"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.1",
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.9.0",
    "@typescript-eslint/parser": "^8.9.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.3",
    "sharp": "^0.35.1",
    "typescript": "^5.6.2",
    "vite": "^7.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4"
  }
}
